<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ appName }}</title>
    <meta
      name="description"
      content="A real AdonisJS hypermedia starter with sessions, authentication, Shield, rate limiting, mailers, Edge views, and Vite assets."
    />
    @vite(["resources/js/app.js"])
  </head>
  <body>
    <div class="shell" x-data="starterSpotlight">
      <header class="site-header">
        <div class="site-header__brand">
          <a href="/" aria-label="Home">{{ appName }}</a>
        </div>
        <nav class="site-header__nav" aria-label="Primary">
          <a href="https://docs.adonisjs.com">Docs</a>
          <a href="/health">Health</a>
          @if(isAuthenticated)
            <a href="/app">Dashboard</a>
          @else
            <a href="/register">Register</a>
            <a href="/login">Login</a>
          @endif
        </nav>
      </header>
      @flashMessage("success")
        <p class="flash flash--success">{{ $message }}</p>
      @end
      @flashMessage("error")
        <p class="flash flash--error">{{ $message }}</p>
      @end
      <main>
        <section class="hero">
          <p class="hero__eyebrow">{{ starterContent.eyebrow }}</p>
          <h1>{{ starterContent.title }}</h1>
          <p class="hero__body">
            {{ starterContent.body }}
          </p>
          <div class="hero__actions">
            @if(isAuthenticated)
              <a class="button button--primary" href="/app">Open the dashboard</a>
            @else
              <a class="button button--primary" href="/register">Create an account</a>
              <a class="button button--secondary" href="/login">Sign in</a>
            @endif
          </div>
          <div class="stack-list" aria-label="Starter stack">
            @each(item in starterContent.stack)
              <span class="stack-pill">{{ item }}</span>
            @end
          </div>
        </section>
        <section class="feature-grid" aria-label="Starter highlights">
          <article
            class="feature-card"
            :class="{ 'feature-card--active': active === 'hypermedia' }"
          >
            <h2>Hypermedia-first</h2>
            <p>
              Routes render Edge views directly, CSRF-protected forms submit to
              controllers, and session flash state returns feedback to the UI.
            </p>
            <button
              class="feature-card__toggle"
              type="button"
              @click="setActive('hypermedia')"
            >
              Focus this area
            </button>
          </article>
          <article
            class="feature-card"
            :class="{ 'feature-card--active': active === 'security' }"
          >
            <h2>Secure by default</h2>
            <p>
              Session auth, password hashing, Shield middleware, and login/signup
              rate limiting are part of the starter rather than left as placeholders.
            </p>
            <button
              class="feature-card__toggle"
              type="button"
              @click="setActive('security')"
            >
              Focus this area
            </button>
          </article>
          <article
            class="feature-card"
            :class="{ 'feature-card--active': active === 'operations' }"
          >
            <h2>Operational baseline</h2>
            <p>
              The application keeps a health endpoint, structured config, mailer
              delivery, test coverage, and deployment-friendly Vite builds.
            </p>
            <button
              class="feature-card__toggle"
              type="button"
              @click="setActive('operations')"
            >
              Focus this area
            </button>
          </article>
        </section>
        @if(isAuthenticated && user)
          <section class="summary-card" aria-label="Current session">
            <p class="summary-card__eyebrow">Current session</p>
            <h2>{{ user.username }}</h2>
            <p>{{ user.email }}</p>
            <p>
              Signed in with the same session-backed flow that protects the dashboard.
            </p>
          </section>
        @endif
      </main>
      <footer class="site-footer">
        <p>
          Need help wiring this into a product? Start with the docs and the
          support address configured in the provider: {{ supportEmail }}.
        </p>
      </footer>
    </div>
  </body>
</html>
