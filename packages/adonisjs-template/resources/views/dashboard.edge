<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard | {{ appName }}</title>
    @vite(["resources/js/app.js"])
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <div class="site-header__brand">
          <a href="/">AdonisJS Starter</a>
        </div>
        <nav class="site-header__nav" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/health">Health</a>
        </nav>
      </header>
      @flashMessage("success")
        <p class="flash flash--success">{{ $message }}</p>
      @end
      <main>
        <section class="hero">
          <p class="hero__eyebrow">Dashboard</p>
          <h1>Welcome back, {{ user.username }}.</h1>
          <p class="hero__body">
            Your session is active, your password is hashed in the database, and
            the surrounding request pipeline is protected by Shield and the auth
            middleware stack.
          </p>
        </section>
        <section class="feature-grid" aria-label="Account actions">
          <article class="feature-card feature-card--active">
            <h2>Identity</h2>
            <p>{{ user.email }}</p>
            <p>Created at {{ user.createdAt }}</p>
          </article>
          <article class="feature-card">
            <h2>Session</h2>
            <p>
              This page is available only after authentication and redirects guests
              back to the login screen.
            </p>
          </article>
          <article class="feature-card">
            <h2>Mail + limiter</h2>
            <p>
              Registration sends a welcome mail and login/signup forms are protected
              by rate limiting middleware.
            </p>
          </article>
        </section>
        <section class="action-row">
          <form action="/logout" method="post">
            {{ csrfField() }}
            <button class="button button--primary" type="submit">Sign out</button>
          </form>
          <form action="/account/delete" method="post">
            {{ csrfField() }}
            <button class="button button--secondary" type="submit">
              Delete account
            </button>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>
