# 1st time Deploy

# server_type ~/github.com/pbizopoulos/canonicalization/packages/deploy_adonisjs_host_template/main.tf at least cpx22
# Follow this: https://docs.hetzner.com/cloud/api/getting-started/generating-api-token/
git clone git@github.com:pbizopoulos/canonicalization ~/github.com/pbizopoulos/canonicalization/
cd ~/github.com/pbizopoulos/canonicalization/
cd secrets/
nix run github:ryantm/agenix -- -e secrets.age
# put hetnzer token in TF_VAR_hcloud_token=...
# generate a random password for APP_KEY=...
cd ..
cd packages/deploy_adonisjs_host_template/
nix run .#deploy_adonisjs_host_template
# ssh-keyscan the prm/ipv4_address and put the key in prm/adonisjs-template.pub
bash prm/agenix-rekey.sh
cd packages/deploy_adonisjs_host_template/
nix run .#deploy_adonisjs_host_template

# delete server
rm -rf tmp/deploy_adonisjs_host_template.tfstate*
# disable protection and delete server from console.hetzner
