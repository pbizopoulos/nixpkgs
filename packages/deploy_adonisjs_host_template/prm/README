# real deployment procedure
# 1. Initialize `secrets/secrets.age` with the example template.
EDITOR="cp secrets/secrets.env.example" nix run github:ryantm/agenix -- -e secrets/secrets.age

# 2. Generate a secure `APP_KEY` for AdonisJS.
node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# 3. Set your real `APP_KEY` and `TF_VAR_hcloud_token` in the secrets file.
nix run github:ryantm/agenix -- -e secrets/secrets.age

# 4. If you need to use a different SSH key name or server type, edit:
# packages/deploy_adonisjs_host_template/main.tf

# 5. Ensure the Hetzner SSH key already exists in your account.
# 6. Rekey or re-encrypt `secrets/secrets.age` so your local user key can decrypt it.
bash prm/agenix-rekey.sh

# 7. Perform the first remote deployment.
nix run .#deploy_adonisjs_host_template

# 8. Fetch the new host SSH public key and re-encrypt secrets for the host.
bash prm/post-deploy.sh adonisjs_host_template

# 9. Deploy again so the host can decrypt its secrets.
nix run .#deploy_adonisjs_host_template
