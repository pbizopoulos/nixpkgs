{
  "name": "symfony_supabase_template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "php -S 0.0.0.0:8000 -t public",
    "format": "nix fmt",
    "build": "composer install --no-interaction",
    "start": "php -S 0.0.0.0:8000 -t public",
    "test": "npm run test:unit && npm run test:e2e && npm run test:cpd && npm run test:audit",
    "test:unit": "php bin/phpunit",
    "test:e2e": "playwright test",
    "test:cpd": "jscpd .",
    "db:start": "supabase start",
    "db:stop": "supabase stop"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "jscpd": "^4.0.5"
  }
}
