{
  "name": "qwik_supabase_template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "qwik dev",
    "format": "nix fmt",
    "build": "qwik build",
    "start": "qwik start",
    "test": "npm run test:unit && npm run test:e2e && npm run test:cpd && npm run test:audit",
    "test:unit": "vitest run",
    "test:e2e": "E2E_MODE=prod playwright test",
    "test:e2e:dev": "playwright test",
    "test:audit": "npm run build && E2E_MODE=prod playwright test --project=audit",
    "test:visual": "E2E_MODE=prod playwright test --update-snapshots",
    "test:cpd": "jscpd .",
    "db:start": "supabase start",
    "db:stop": "supabase stop"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.5.5",
    "@builder.io/qwik-city": "^1.5.5",
    "@supabase/ssr": "^0.8.0"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "vitest": "^4.0.18",
    "jscpd": "^4.0.5"
  }
}
