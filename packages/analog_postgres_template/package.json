{
  "name": "analog_postgres_template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "ng serve",
    "format": "nix fmt",
    "build": "ng build",
    "start": "node dist/analog/server/main.js",
    "test": "npm run test:unit && npm run test:e2e && npm run test:cpd && npm run test:audit",
    "test:unit": "vitest run",
    "test:e2e": "E2E_MODE=prod playwright test",
    "test:e2e:dev": "playwright test",
    "test:audit": "npm run build && E2E_MODE=prod playwright test --project=audit",
    "test:visual": "E2E_MODE=prod playwright test --update-snapshots",
    "test:cpd": "jscpd .",
    "db:start": "postgres start",
    "db:stop": "postgres stop"
  },
  "dependencies": {
    "@analogjs/content": "^1.0.0",
    "@analogjs/router": "^1.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.0",
    "@supabase/ssr": "^0.8.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^1.0.0",
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@playwright/test": "1.57.0",
    "typescript": "~5.2.0",
    "vitest": "^4.0.18",
    "jscpd": "^4.0.5"
  }
}
