{
  "name": "laravel_postgres_template",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "php artisan serve",
    "format": "nix fmt",
    "build": "php artisan build",
    "start": "php artisan serve",
    "test": "npm run test:unit && npm run test:e2e && npm run test:cpd",
    "test:unit": "php artisan test",
    "test:e2e": "playwright test",
    "test:cpd": "jscpd .",
    "db:start": "postgres start",
    "db:stop": "postgres stop"
  },
  "devDependencies": {
    "jscpd": "^4.0.5",
    "@playwright/test": "1.57.0"
  }
}
