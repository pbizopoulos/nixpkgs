# 1st time Deploy

git clone git@github.com:pbizopoulos/canonicalization ~/github.com/pbizopoulos/canonicalization/
cd ~/github.com/pbizopoulos/canonicalization/
# server_type ~/github.com/pbizopoulos/canonicalization/packages/deploy_host_template/main.tf at least cpx22

# Domain name is optional.
# Without a domain, the template deploys over plain HTTP and is reachable by IP/hostname.
# If you want HTTPS, you must set your own real domain in hosts/template/configuration.nix
# before deployment:
# - add your domain to services.template-app.allowedHosts
# - set services.template-app.csrfTrustedOrigins = [ "https://<your-domain>" ]
# - set services.template-app.nginx.serverName = "<your-domain>"
# - set services.template-app.nginx.enableACME = true
# - set services.template-app.nginx.forceSSL = true
# - set services.template-app.publicUrl = "https://<your-domain>"
# - add a matching security.acme configuration and email address

cd secrets/
nix run github:ryantm/agenix -- -e secrets.age
# Upload your public ssh key named default in https://console.hetzner.com/projects/<project-id>/security/sshkeys
# Generate an API token named default in https://console.hetzner.com/projects/<project-id>/security/tokens
# put hetnzer token in TF_VAR_hcloud_token=...
# generate a random password for APP_KEY=...
cd ..
cd packages/deploy_host_template/
nix run .#deploy_host_template
# ssh-keyscan the prm/ipv4_address and put the key in prm/template.pub
bash prm/agenix-rekey.sh
cd packages/deploy_host_template/
nix run .#deploy_host_template

# delete server
rm -rf tmp/deploy_host_template.tfstate*
# disable protection and delete server from console.hetzner
# (if needed) Remove API token named default in https://console.hetzner.com/projects/<project-id>/security/tokens
