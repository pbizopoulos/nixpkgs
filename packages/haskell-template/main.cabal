name:          haskell-template
version:       0.0.0
synopsis:      Hello World Haskell
cabal-version: >=1.10
build-type:    Simple
executable haskell-template
  main-is:          Main.hs
  build-depends:
      base
    , HUnit
  ghc-options:      -O2 -Weverything -Werror -threaded -fhpc
  default-language: Haskell2010
