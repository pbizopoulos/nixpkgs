<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AdonisJS Hypermedia Starter</title>
    <meta
      name="description"
      content="A clean AdonisJS hypermedia starter with controllers, models, validators, Edge views, and test coverage."
    />
    @vite(["resources/js/app.js"])
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <div class="site-header__brand">
          <a href="/" aria-label="Home">AdonisJS Starter</a>
        </div>
        <nav class="site-header__nav" aria-label="Primary">
          <a href="https://docs.adonisjs.com">Docs</a>
          <a href="https://adocasts.com">Tutorials</a>
        </nav>
      </header>
      <main>
        <section class="hero">
          <p class="hero__eyebrow">Hypermedia starter</p>
          <h1>Build the app, not the scaffold.</h1>
          <p class="hero__body">
            This template follows the AdonisJS hypermedia starter shape with Edge
            views, resources assets, controllers, models, validators, and a clean
            Edge-rendered starting experience you can evolve into a real product.
          </p>
          <div class="hero__actions">
            <a class="button button--primary" href="https://docs.adonisjs.com">
              Read the docs
            </a>
            <a
              class="button button--secondary"
              href="https://docs.adonisjs.com/guides/concepts/deployment"
            >
              Deploy the app
            </a>
          </div>
        </section>
        <section class="feature-grid" aria-label="Starter highlights">
          <article class="feature-card">
            <h2>Hypermedia-first</h2>
            <p>
              Start from routes and Edge views in the same shape as the official
              hypermedia starter.
            </p>
          </article>
          <article class="feature-card">
            <h2>Domain-ready</h2>
            <p>
              Controllers, models, transformers, and validators already back a
              working username lifecycle.
            </p>
          </article>
          <article class="feature-card">
            <h2>Tested baseline</h2>
            <p>
              Unit, functional, and browser coverage stay in place while you reshape
              the starter around your product.
            </p>
          </article>
        </section>
      </main>
    </div>
  </body>
</html>
