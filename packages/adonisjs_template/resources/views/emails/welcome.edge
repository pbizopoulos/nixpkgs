<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Welcome to {{ brandName }}</title>
  </head>
  <body>
    <h1>Welcome, {{ user.username }}</h1>
    <p>Your {{ brandName }} account is ready.</p>
    <p>Email: {{ user.email }}</p>
    <p>You can now sign in and continue from the dashboard.</p>
  </body>
</html>
