{
  "name": "adonisjs_template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#database/*": "./database/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#mails/*": "./app/mails/*.js",
    "#models/*": "./app/models/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#validators/*": "./app/validators/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#providers/*": "./providers/*.js"
  },
  "bin": {
    "adonisjs_template": "scripts/entrypoint.js"
  },
  "scripts": {
    "clean": "rm -rf build coverage reports test-results .stryker-tmp tsconfig.tsbuildinfo",
    "db:init": "bash scripts/pg.sh init",
    "db:start": "bash scripts/pg.sh start",
    "db:stop": "bash scripts/pg.sh stop",
    "db:status": "bash scripts/pg.sh status",
    "db:createdb": "bash scripts/pg.sh createdb",
    "db:reset": "bash scripts/pg.sh reset",
    "db:migrate": "node ace.js migration:run --force",
    "db:seed": "node ace.js db:seed",
    "dev": "node ace.js serve --hmr",
    "dev:full": "npm run db:start && npm run db:createdb && npm run db:migrate && npm run dev",
    "build": "node ace.js build",
    "start": "node build/bin/server.js",
    "test": "node ace.js test",
    "test:coverage": "c8 --all --src app --src start --exclude start/kernel.ts --exclude start/routes.ts --exclude start/env.ts --reporter=text-summary --reporter=html --report-dir coverage node ace.js test",
    "test:ci": "bash scripts/test-ci.sh",
    "test:e2e": "E2E_MODE=prod playwright test",
    "test:lint": "npm run clean && jscpd --ignore build,bin,node_modules,scripts,.adonisjs . && depcruise app bin config resources start",
    "test:mutation": "stryker run",
    "test:visual": "npm run build && npm run test:e2e -- --update-snapshots"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lucid": "^22.4.0",
    "@adonisjs/mail": "^10.2.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@types/luxon": "^3.7.1",
    "@vinejs/vine": "^4.3.0",
    "alpinejs": "^3.15.9",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.3.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@adonisjs/vite": "^5.1.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@playwright/test": "1.58.2",
    "@poppinss/ts-exec": "^1.4.4",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "dependency-cruiser": "^17.3.10",
    "hot-hook": "^1.0.0",
    "jscpd": "^4.0.8",
    "pino-pretty": "^13.1.3",
    "typescript": "~6.0.2",
    "vite": "^7.3.1",
    "youch": "^4.1.1"
  }
}
