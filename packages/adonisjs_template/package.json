{
  "name": "adonisjs_template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#exceptions/*": "./app/exceptions/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "bin": {
    "adonisjs_template": "scripts/entrypoint.js"
  },
  "scripts": {
    "clean": "rm -rf build coverage reports .stryker-tmp",
    "db:init": "bash scripts/pg.sh init",
    "db:start": "bash scripts/pg.sh start",
    "db:stop": "bash scripts/pg.sh stop",
    "db:status": "bash scripts/pg.sh status",
    "db:createdb": "bash scripts/pg.sh createdb",
    "db:reset": "bash scripts/pg.sh reset",
    "db:migrate": "node ace migration:run --force",
    "dev": "node ace serve --hmr",
    "dev:full": "npm run db:start && npm run db:createdb && npm run db:migrate && npm run dev",
    "build": "node ace build",
    "start": "node build/bin/server.js",
    "test": "bash scripts/test.sh",
    "test:e2e": "E2E_MODE=prod playwright test",
    "test:lint": "npm run clean && jscpd --ignore build,bin,node_modules . && depcruise app bin config resources start",
    "test:mutation": "stryker run && node -e \"const fs=require('node:fs'),{calculateMetrics}=require('mutation-testing-metrics'),report=JSON.parse(fs.readFileSync('reports/mutation/mutation.json','utf-8')),metrics=calculateMetrics(report.files);console.log(JSON.stringify(metrics.metrics,null,2))\"",
    "test:visual": "npm run build && npm run test:e2e -- --update-snapshots"
  },
  "dependencies": {
    "@adonisjs/core": "^7.1.1",
    "@adonisjs/lucid": "^22.2.0",
    "@adonisjs/static": "^2.0.1",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.3.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@playwright/test": "1.58.2",
    "@poppinss/ts-exec": "^1.4.4",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dependency-cruiser": "^17.3.9",
    "hot-hook": "^1.0.0",
    "jscpd": "^4.0.8",
    "mutation-testing-metrics": "^3.7.3",
    "pino-pretty": "^13.1.3",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2",
    "youch": "^4.1.0"
  }
}
