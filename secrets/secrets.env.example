# Secrets (must be set in secrets.age)
# Generate a key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_KEY=01234567890123456789012345678901
# Hetzner Cloud API Token
TF_VAR_hcloud_token=sample-hetzner-token
# Runtime values like HOST, PORT, APP_URL, and DB_* are defined by
# hosts/adonisjs_template/configuration.nix for the nginx-backed deployment.
